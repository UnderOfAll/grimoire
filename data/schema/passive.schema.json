{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Passive / Feature / Feat",
  "type": "object",
  "required": ["name", "type", "description"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "type": { "type": "string", "enum": ["Feat", "Racial Trait", "Class Feature", "Passive"], "description": "kind of passive ability" },
    "source": { "type": "string", "default": "5e SRD" },
    "prerequisite": { "type": ["string", "null"] },
    "description": { "type": "string" }
  }
}
